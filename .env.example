# 公网域名，不包含协议
DOMAIN=example.com
# 生产环境留空以启用自动 HTTPS；仅本地/CI 的 HTTP 冒烟测试设置为 http://
CADDY_SCHEME=

# PostgreSQL（生产环境务必使用强随机密码）
DB_NAME=monster_homepage
DB_USER=monster
DB_PASSWORD=replace-with-a-long-random-database-password
DB_POOL_SIZE=5

# 单管理员账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-long-random-admin-password
APP_SEED_DATA=true

# 访问统计匿名哈希盐（使用 openssl rand -hex 32 生成）
ANALYTICS_SALT=replace-with-a-long-random-analytics-salt

# HTTPS 生产环境保持 true；本地直接访问 API 时可改为 false
SESSION_COOKIE_SECURE=true
SESSION_TIMEOUT=8h

# JVM 内存参数，2C4G 服务器建议限制容器资源后再调整
JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=70 -XX:+UseG1GC

# 本地构建默认无需修改；自动部署会覆盖为 GHCR 镜像
API_IMAGE=monster-homepage-api:local
WEB_IMAGE=monster-homepage-web:local
